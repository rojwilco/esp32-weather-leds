#ifndef SECRETS_H
#define SECRETS_H

#define WIFI_SSID      "your-wifi-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// Location is now configured at runtime via the web UI (http://<device-ip>/).
// DEFAULT_LATITUDE and DEFAULT_LONGITUDE in the sketch serve as compile-time
// fallbacks until you save your coordinates through the browser form.
//
// If your local secrets.h has #define LATITUDE or #define LONGITUDE lines
// from an earlier version of this sketch, remove them — those names are no
// longer used and will generate unused-macro warnings.

#endif
